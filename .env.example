# ─── Domain ───────────────────────────────────────────────────────────────────
# Your production domain (no http/https prefix)
DOMAIN=yourdomain.com

# Email for Let's Encrypt certificate notifications
CERTBOT_EMAIL=you@yourdomain.com

# ─── Hetzner Server ───────────────────────────────────────────────────────────
# IP address or hostname of your Hetzner CX23
SERVER_HOST=1.2.3.4

# SSH user (root for fresh Hetzner Ubuntu image)
SERVER_USER=root

# Path on the server where the repo will live
DEPLOY_DIR=/opt/zdenovo

# ─── Repository ───────────────────────────────────────────────────────────────
# Git remote URL — used by server-setup.sh to clone on first deploy
REPO_URL=https://github.com/youruser/zdenovo.git

# ─── LLM Generation ───────────────────────────────────────────────────────────
# Anthropic API key for POST /api/posts/generate
# Dev: add to local .env (gitignored)
# Prod: add to server's .env at $DEPLOY_DIR/.env (never committed)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ─── Unsplash (blog hero images) ──────────────────────────────────────────────
# Free API key from https://unsplash.com/developers — 50 req/hr on demo tier
UNSPLASH_ACCESS_KEY=your-unsplash-access-key-here

# ─── Admin Auth ───────────────────────────────────────────────────────────────
# Password for the single admin user (protects all /admin/* routes)
ADMIN_PASSWORD=change-me

# Random secret for signing session cookies — generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key