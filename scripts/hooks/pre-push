#!/usr/bin/env bash
set -euo pipefail

# Only run the full test suite when pushing to main.
PUSHING_TO_MAIN=false
while read -r local_ref local_sha remote_ref remote_sha; do
  if [[ "$remote_ref" == "refs/heads/main" ]]; then
    PUSHING_TO_MAIN=true
  fi
done

if [[ "$PUSHING_TO_MAIN" != "true" ]]; then
  exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
BACKEND="$REPO_ROOT/backend"
LOG_FILE="$REPO_ROOT/.pre-push.log"

# Tee all output to log file AND stdout so progress is always visible
exec > >(tee "$LOG_FILE") 2>&1

ts() { echo "[$(date '+%H:%M:%S')] $*"; }

FULL="${FULL:-0}"

if [[ "$FULL" == "1" ]]; then
  ts "=== Pre-push to main: full gate (unit + Playwright + security) ==="
else
  ts "=== Pre-push to main: fast gate (unit + security, no Playwright) ==="
fi
ts "Log: $LOG_FILE"
echo ""

# Load .env so Playwright tests can read ADMIN_PASSWORD
if [[ -f "$REPO_ROOT/.env" ]]; then
  set -a
  source "$REPO_ROOT/.env"
  set +a
fi

if ! curl -s -o /dev/null -w '' --connect-timeout 2 http://localhost:8080/ 2>/dev/null; then
  ts "ERROR: App not running on localhost:8080. Start it with 'docker compose up -d' first."
  exit 1
fi

# ── Unit tests ────────────────────────────────────────────────────────────────
ts "--- [1/5] Unit tests ---"
cd "$BACKEND"
uv run pytest tests/test_db.py tests/test_data.py tests/test_api.py tests/test_routes.py tests/test_auth.py tests/test_comments.py tests/test_drafts.py tests/test_topics.py -v --tb=short || {
  ts "FAILED: Unit tests did not pass. Push aborted."
  ts "Full log: $LOG_FILE"
  exit 1
}
ts "✓ Unit tests passed"
echo ""

# ── Playwright frontend tests ─────────────────────────────────────────────────
if [[ "$FULL" == "1" ]]; then
  ts "--- [2/5] Frontend tests (Playwright) ---"
  uv run pytest tests/test_frontend.py -v --tb=short -k "not regenerate" || {
    ts "FAILED: Frontend tests did not pass. Push aborted."
    ts "Full log: $LOG_FILE"
    exit 1
  }
  ts "✓ Frontend tests passed"
else
  ts "--- [2/5] Frontend tests (Playwright) --- SKIPPED (run with FULL=1 to include)"
fi
echo ""

# ── bandit ────────────────────────────────────────────────────────────────────
ts "--- [3/5] Security: bandit ---"
cd "$BACKEND"
uv run bandit -r . -c pyproject.toml --severity-level medium -q || {
  ts "FAILED: bandit found security issues. Push aborted."
  ts "Full log: $LOG_FILE"
  exit 1
}
ts "✓ bandit clean"
echo ""

# ── pip-audit ─────────────────────────────────────────────────────────────────
ts "--- [4/5] Security: pip-audit ---"
uv run pip-audit -l && ts "✓ No known vulnerabilities" || {
  ts "FAILED: pip-audit found vulnerable dependencies."
  ts "Full log: $LOG_FILE"
  exit 1
}
echo ""

# ── Route auth audit ──────────────────────────────────────────────────────────
ts "--- [5/5] Security: route auth audit ---"
cd "$BACKEND"
uv run python "$REPO_ROOT/scripts/route-auth-audit.py" || {
  ts "FAILED: Route auth audit found unprotected endpoints."
  ts "Full log: $LOG_FILE"
  exit 1
}
ts "✓ All routes protected"
echo ""

ts "=== All checks passed. Pushing to main. ==="
