{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(uv *)",
      "Bash(docker *)",
      "Bash(docker compose *)",
      "Bash(curl *)",
      "Bash(make *)",
      "Bash(ls *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(sleep *)",
      "Bash(ss *)",
      "Bash(which *)",
      "Bash(test *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(python3 *)",
      "Bash(cd *)",
      "Bash(pwd)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(sort *)",
      "Bash(mkdir *)",
      "Bash(chmod *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Read(**)",
      "Edit(**)",
      "Write(**)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(sudo rm *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[hook] modified: $(echo $CLAUDE_TOOL_INPUT | jq -r '.file_path // empty' 2>/dev/null)\""
          }
        ]
      }
    ]
  },
  "env": {
    "NODE_ENV": "development"
  },
  "sandbox": {
    "network": {
      "allowLocalBinding": true,
      "allowedDomains": ["localhost", "127.0.0.1"]
    }
  }
}
